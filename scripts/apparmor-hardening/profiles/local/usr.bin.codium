# Site-specific additions and overrides for the VSCodium profile.
# Add rules here to customize the Codium AppArmor profile without
# editing the main profile file directly.
#
# This file is included by the main profile via:
#   include if exists <local/usr.bin.codium>
#
# Example: Allow access to an additional project directory
#   /data/projects/** rwkl,
#
# Example: Allow a specific MCP server binary
#   /usr/local/bin/my-mcp-server ix,
